# HTTP 服务器 - 强制跳转到 HTTPS
server {
    listen 80;
    server_name jingcc.cc www.jingcc.cc 47.99.202.3 life.jingcc.cc;
    
    # SSL 证书验证路径（Let's Encrypt 文件验证）
    location ^~ /.well-known/acme-challenge/ {
        root /www/wwwroot/ssl_verify;
        try_files $uri =404;
    }
    
    # 强制 HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS 服务器
server {
    listen 443 ssl ;
    http2 on;
    server_name jingcc.cc www.jingcc.cc 47.99.202.3 life.jingcc.cc;
    
    # SSL 证书配置
    ssl_certificate /www/server/panel/vhost/cert/jingcc.cc/fullchain.pem;
    ssl_certificate_key /www/server/panel/vhost/cert/jingcc.cc/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    
    # 日志配置
    access_log /www/wwwlogs/47.99.202.3.log;
    error_log /www/wwwlogs/47.99.202.3.error.log;
    
    # 生活博客路径
    location /life {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # 攻略图片上传目录：持久化服务器文件，不进入 Git 或 .deploy 构建包
    location /uploads/ {
        alias /var/www/TFTBlog-NEXTJS/uploads/;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
    
    # 游戏博客 (默认)
    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
